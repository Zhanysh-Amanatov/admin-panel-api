  "license": "ISC",
  "description": "User CRUD and Auth API",
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/jest": "29.5.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "22.0.0",
    "@types/pg": "8.11.0",
    "@types/supertest": "7.2.1",
    "bcryptjs": "3.0.3",
    "express": "5.2.1",
    "jest": "29.7.0",
    "jsonwebtoken": "9.0.3",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "5.7.2"
  },
  "dependencies": {
    "dotenv": "16.4.0",
    "pg": "8.13.0"
  }
